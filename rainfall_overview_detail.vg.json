{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "The Weight of the Sky",
        "font": "Playfair Display",
        "fontStyle": "normal",
        "fontWeight":"bold",
        "fontSize": 26,
        "anchor": "start",
        "color":"#0a2343"
    },
    "data":{
        "url": "cleaned_rainfall_2020_2024.csv",
        "format":{"type": "csv","parse":{"YearMonth": "date:'%Y-%m'"}}
    },
    "spacing": 22,
    "vconcat": [
        {
            "width":900,
            "height": 350,
            "layer": [
                {
                    "data":{
                        "values":[
                            {"start":"2020-01-01", "end":"2020-02-01", "season":"Northeast Monsoon"},
                            {"start":"2020-10-01", "end":"2021-02-01", "season": "Northeast Monsoon"},
                            {"start":"2021-10-01", "end":"2022-02-01", "season": "Northeast Monsoon"},
                            {"start":"2022-10-01", "end":"2023-02-01", "season": "Northeast Monsoon"},
                            {"start":"2023-10-01", "end":"2024-02-01", "season": "Northeast Monsoon"},
                            {"start":"2024-10-01", "end":"2024-12-01", "season": "Northeast Monsoon"}
                    ]
                    },
                    "transform": [
                        {
                            "calculate": "toDate(datum.start)",
                            "as": "start_date"
                        },
                        {
                            "calculate": "toDate(datum.end)",
                            "as": "end_date"
                        }
                    ],
                    "mark":{
                        "type": "rect",
                        "color":"#e05a4a",
                        "opacity":0.15
                    },
                    "encoding": {
                        "x":{
                            "field":"start",
                            "type": "temporal",
                            "scale":{
                                "domain":{"param": "brush"}
                            }
                        },
                        "x2":{"field":"end_date"},
                        "tooltip":[
                        {
                            "field":"season",
                            "type": "nominal",
                            "title":"Season"
                        }
                    ]
                    }
                    

                },
                {
                    "mark":{
                        "type": "area",
                        "line": true,
                        "color": "#2b5876",
                        "fillOpacity": 0.15,
                        "strokeWidth": 2,
                        "clip":true
                    },
                    "encoding": {
                        "x": {
                            "field": "YearMonth",
                            "type": "temporal",
                            "scale":{
                                "domain":{
                                    "param": "brush"
                                }
                            },
                            "axis": {
                                "title": null,
                                "labelAngle": -30,
                                "labelFont": "DM Sans",
                                "labelFontSize": 12,
                                "labelColor":"#2b5876",
                                "grid": false,
                                "format": "%b %Y",
                                "tickCount": 12
                            }
                        },
                        "y": {
                            "field": "pr",
                            "type": "quantitative",
                            "axis":{
                                "title": "Precipitation (mm)",
                                "titleFont": "DM Sans",
                                "titleFontSize": 13,
                                "titleColor":"#2b5876",
                                "labelFont": "DM Sans",
                                "labelFontSize": 12,
                                "labelColor":"#2b5876",
                                "grid": true,
                                "gridColor": "#dce4ed",
                                "gridOpacity":0.85
                            }
                        },
                        "tooltip":[
                            {
                                "field": "YearMonth",
                                "type": "temporal",
                                "title": "Month",
                                "format":"%b %Y"
                            },
                            {
                                "field":"pr",
                                "type": "quantitative",
                                "title":"Precipitation (mm)",
                                "format": ".1f"
                            },
                            {
                                "field":"r20mm",
                                "type": "quantitative",
                                "title":"Heavy Rain Days",
                                "format": ".1f"
                            }
                        ]
                    }
                },
                {
                    "mark":{
                        "type": "line",
                        "color": "#5ba4c4",
                        "strokeWidth": 2,
                        "strokeDash":[5, 3],
                        "clip":true
                    },
                    "encoding": {
                        "x":{
                            "field":"YearMonth",
                            "type": "temporal",
                            "scale":{"domain":{
                                "param": "brush"
                            }}
                        },
                        "y":{
                            "field":"r20mm",
                            "type": "quantitative",
                            "axis":{
                                "title":"Heavy Rain Days",
                                "titleFont":"DM Sans",
                                "titleFontSize": 13,
                                "titleColor":"#5ba4c4",
                                "labelFont": "DM Sans",
                                "labelFontSize": 12,
                                "labelColor":"#5ba4c4",
                                "grid": false,
                                "orient":"right"
                            }
                        },
                        "tooltip":[
                            {
                                "field":"YearMonth",
                                "type": "temporal",
                                "title": "Month",
                                "format":"%b %Y"
                            },
                            {
                                "field":"pr",
                                "type": "quantitative",
                                "title":"Precipitation (mm)",
                                "format": ".1f"
                            },
                            {
                                "field":"r20mm",
                                "type": "quantitative",
                                "title":"Heavy Rain Days",
                                "format":".1f"
                            }
                        ]
                    }
                },
                {
                    "transform": [
                        {
                            "window": [
                                {
                                    "op":"rank",
                                    "as": "rain_rank"
                                }
                            ],
                            "sort": [
                                {
                                    "field": "pr",
                                    "order":"descending"
                                }
                            ]
                        },
                        {
                            "filter":"datum.rain_rank == 1"
                        }
                    ],
                    "mark":{
                        "type": "rule",
                        "color" :"#b03022",
                        "strokeWidth":1.4,
                        "strokeDash":[4,4]
                    },
                    "encoding": {
                        "x":{"field":"YearMonth",
                    "type": "temporal",
                "scale":{
                    "domain":{
                        "param": "brush"
                    }
                }}
                    }
                },
                {
                    "transform": [
                        {
                            "window": [
                                {
                                    "op":"rank",
                                    "as": "rain_rank"
                                }
                            ],
                            "sort": [
                                {
                                    "field": "pr",
                                    "order":"descending"
                                }
                            ]
                        },
                        {
                            "filter":"datum.rain_rank == 1"
                        }
                    ],
                    "mark":{
                        "type": "point",
                        "filled":true,
                        "size":95,
                        "color":"#b03022",
                        "stroke":"#ffffff",
                        "strokeWidth":1.5
                    },
                    "encoding": {
                        "x":{"field":"YearMonth",
                    "type": "temporal",
                "scale":{"domain":{"param": "brush"}}},
                "y":{"field":"pr",
                "title":null,
            "type": "quantitative"},
            "tooltip":[
                            {
                                "field":"YearMonth",
                                "type": "temporal",
                                "title": "Month",
                                "format":"%b %Y"
                            },
                            {
                                "field":"pr",
                                "type": "quantitative",
                                "title":"Precipitation (mm)",
                                "format": ".1f"
                            },
                            {
                                "field":"r20mm",
                                "type": "quantitative",
                                "title":"Heavy Rain Days",
                                "format":".1f"
                            }
                        ]
                    }
                },
                {
                    "transform": [
                        {
                            "window": [
                                {
                                    "op":"rank",
                                    "as": "rain_rank"
                                }
                            ],
                            "sort": [
                                {
                                    "field": "pr",
                                    "order":"descending"
                                }
                            ]
                        },
                        {
                            "filter":"datum.rain_rank == 1"
                        }
                    ],
                    "mark":{
                        "type": "text",
                        "align":"right",
                        "baseline":"middle",
                        "dx":-10,
                        "dy":5,
                        "font":"DM Sans",
                        "fontSize":11,
                        "fontWeight":"bold",
                        "fill":"#b03022",
                        "text":"Highest Rainfall Month"
                    },
                    "encoding": {
            "x": {
              "field": "YearMonth",
              "type": "temporal",
              "scale": {
                "domain": {
                  "param": "brush"
                }
              }
            },
            "y": {
              "field": "pr",
              "title":null,
              "axis":null,
              "type": "quantitative"
            }
          }
        },
                {
                    "data":{
                        "values":[
                            {
                                "label":"Northeast Monsoon Window"
                            }
                        ]
                    },
                    "mark":{
                        "type": "rect",
                        "fill":"#e05a4a",
                        "strokeWidth":1,
                        "fillOpacity":0.25
                    },
                    "encoding": {
                        "x":{
                            "value":20
                        },
                        "x2":{"value":40},
                        "y":{"value":16},
                        "y2":{"value":30}
                    }
                },
                {
                    "data":{
                        "values":[
                            {
                                "label":"Northeast Monsoon Window"
                            }
                        ]
                    },
                    "mark":{
                        "type": "text",
                        "align":"left",
                        "baseline":"middle",
                        "dx":7,
                        "font":"DM Sans",
                        "fontSize":12,
                        "fontWeight":"bold",
                        "fill":"#6b7c93"
                    },
                    "encoding": {
                        "x":{"value":40},
                        "y":{"value":23},
                "text":{"field":"label"}
                    }
                }
            ],
            "resolve": {
                "scale": {"y": "independent"}
            }
        },
        {
            "width": 900,
            "height":65,
            "params": [
                {
                    "name": "brush",
                    "select":{"type": "interval", "encodings": ["x"]}
                }
                    ],
                    "mark": {
                        "type": "area",
                        "line":true,
                        "color":"#5ba4c4",
                        "fillOpacity": 0.15,
                        "strokeWidth": 1.5
                    },
                    "encoding": {
                        "x":{
                            "field":"YearMonth",
                            "type": "temporal",
                            "axis":{
                                "title":"Drag to select time range",
                                "titleFont":"DM Sans",
                                "titleFontSize":13,
                                "titleColor":"#526578",
                                "labelFont":"DM Sans",
                                "labelFontSize":12,
                                "labelAngle":-30,
                                "labelColor":"#6b7c93",
                                "grid": false,
                                "format":"%b %Y"
                            }
                        },
                        "y":{
                            "field":"pr",
                            "type": "quantitative",
                            "axis":null
                        }
                    }
        }
    ],
    "config": {
        "font": "DM Sans",
        "view": {"stroke":null},
        "axis": {
            "labelFont":"DM Sans",
            "titleFont":"DM Sans",
            "labelFontSize": 12,
            "titleFontSize":13,
            "labelColor":"#2c3e50",
            "titleColor":"#0d1b2a",
            "domainColor":"#dce4ed",
            "tickColor":"#dce4ed",
            "gridColor":"#dce4ed"
        },
        "legend": {
            "labelFont":"DM Sans",
            "titleFont":"DM Sans",
            "labelFontSize":12,
            "titleFontSize":13,
            "titleColor":"#0d1b2a",
            "labelColor":"#2c3e50"
        }
    }
}