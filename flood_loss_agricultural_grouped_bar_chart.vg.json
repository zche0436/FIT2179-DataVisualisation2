{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title":{
        "text": "Loss by Category and State",
        "subtitle": "Proportion of Loss by Agricultural Category",
        "font": "Lora",
        "fontStyle": "normal",
        "fontSize": 24,
        "anchor": "start",
        "subtitleFont": "Inter",
        "subtitleFontSize": 16
    },
    "width": 350,
    "height": 300,
    "params": [
        {
            "name": "year_select",
            "value": 2024,
            "bind": {
                "input": "select",
                "options":[
                    2024, 2025
                ],
                "labels": ["2024", "2025"],
                "name": "Select Year: "
            }
        },
        {
            "name": "state_select",
            "value": "Kedah",
            "bind": {
                "input": "select",
                "options":[
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Kuala Lumpur",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu"
                ],
                "name": "Select State: "
            }
        }
    ],
    "data":{
        "url": "cleaned_floodloss_agricultural.csv"
    },
    "transform": [
        {
            "filter": "datum.Year == year_select"
        },
        {
            "filter": "datum.State == state_select"
        },
        {
            "fold": [
                "Paddy",
                "Crops",
                "Fisheries",
                "Livestock",
                "Fisherman",
                "Agro-entrepreneur",
                "High Value Commodity"
            ],
            "as": [
                "Category",
                "Loss"
            ]
        },
        {
            "filter": "datum.Loss > 0"
        }
    ],
    "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 3,
        "cornerRadiusTopRight": 3
    },
    "encoding": {
        "x":{
            "field":"Category",
            "type": "nominal",
            "sort": {
                "op": "sum",
                "field": "Loss",
                "order":"descending"
            },
            "axis":{
                "labelAngle": -30,
                "labelFont":"Inter",
                "labelFontSize": 12,
                "title":null
            }
        },
        "y":{
            "field":"Loss",
            "type": "quantitative",
            "scale":{
                "type": "log",
                "base": 10
            },
            "axis":{
                "title": "Loss (RM '000)",
                "titleFont": "Inter",
                "titleFontSize": 13,
                "labelFont": "Inter",
                "labelFontSize": 12,
                "grid": false
            }
        },
        "color":{
            "field": "Category",
            "type": "nominal",
            "scale":{
                "domain":[
                    "Paddy",
                    "Crops",
                    "Fisheries",
                    "Livestock",
                    "Fisherman",
                    "Agro-entrepreneur",
                    "High Value Commodity"
                ],
                "range":[
                    "#4a2377",
                    "#8cc5e3",
                    "#f55f74",
                    "#003a7d",
                    "#c99b38",
                    "#ea801c",
                    "#0d7d87"
                ]
            },
            "legend":{
                "title": "Category",
                "titleFont": "Inter",
                "titleFontSize": 13,
                "labelFont": "Inter",
                "labelFontSize": 12
            }
        },
        "tooltip":[
            {
                "field": "Category",
                "type": "nominal",
                "title": "Category"
            },
            {
                "field": "Loss",
                "type": "quantitative",
                "title": "Loss (RM '000)",
                "format": ",d"
            },
            {
                "field":"State",
                "type": "nominal",
                "title": "State"
            },
            {
                "field":"Year",
                "type": "ordinal",
                "title": "Year"
            }
        ]
    },
    "config": {
        "font": "Inter",
        "view": {"stroke": null}
    }
}