{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Flood Loss by State (2024 & 2025)",
    "subtitle": "% of National Loss by State",
    "font": "Lora",
    "fontStyle": "normal",
    "fontSize": 24,
    "anchor": "start",
    "subtitleFont": "Inter",
    "subtitleFontSize": 16
  },
  "width": 900,
  "height": 400,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "projection": {"type": "mercator"},
  "data": {
    "url": "malaysia_map.json",
    "format": {"type": "topojson", "feature": "ne_10m_admin_1_states_provinces"}
  },
  "params": [
    {
        "name": "year_select",
        "value": 2024,
        "bind": {
            "input": "select",
            "options": [
                2024, 2025
            ],
            "labels": [
                "2024",
                "2025"
            ],
            "name": "Select Year: "
        }
    }
  ],
  "layer":[
    {
        "transform": [
            {
                "calculate": "'Data not available in ' + datum.properties.name",
                "as": "fallback_note"
            }
        ],
        "mark": {
            "type": "geoshape",
            "fill": "#eaeaea",
            "stroke": "#ffffff",
            "strokeWidth": 1.2
        },
        "encoding": {
            "tooltip": {"field": "fallback_note", "type": "nominal"}
        }
    },
    {
        "params": [
            {
            "name": "map_state_select",
            "select":{
                "type": "point",
                "fields": ["state_name"],
                "on":"click",
                "toggle": false
            }
    }
        ],
        "transform": [
            {
                "calculate": "datum.properties.name",
                "as": "state_name"
            },
            {
                "calculate": "datum.properties.name + '_' + toString(year_select)",
                "as": "state_year_key"
            },
        {
            "lookup": "state_year_key",
            "from": {
                "data": {"url": "cleaned_floodloss_all.csv"},
                "key": "State_Year",
                "fields": ["Total Loss", "Year", "Living Quaters", "Vehicles", "Business Premises", "Manufacturing", 
                "Agricultural", "Infrastructure"]
            }
        },
        {
            "joinaggregate": [
                {
                    "op": "sum", "field": "Total Loss", "as": "National_Total"
                }
            ]
        },
        {
            "calculate": "datum['Total Loss'] / datum.National_Total * 100",
            "as": "Loss Percentage"
        }
        ],
        "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1, "cursor":"pointer"},
        "encoding": {
            "color": {
            "field": "Loss Percentage",
            "type": "quantitative",
            "scale": {
                "type": "sqrt",
                "range": ["#ffffff", "#67000d"]},
            "title": "% of National Loss",
            "legend":{
                "titleFont":"Inter",
                "titleFontSize" : 13,
                "labelFont": "Inter",
                "labelFontSize": 12,
                "format":".1f"
            }
        },
        "opacity":{
            "condition":{
                "param": "map_state_select",
                "value": 1
            },
            "value": 0.3
        },
            "tooltip": [
            {"field": "properties.name", "type": "nominal", "title": "State"},
            {"field": "Year", "type": "ordinal", "title": "Year"},
            {
                "field":"Loss Percentage",
                "type": "quantitative",
                "title":"% of National Loss",
                "format":".1f"
            },
            {
                "field": "Total Loss", 
                "type": "quantitative", 
                "title": "Total Loss (RM '000)", 
                "format": ",d"
            }
            ]
        }
    }
  ],
  "config": {"font": "Inter"}
}