{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title":{
        "text":"Total Flood Loss by State & Category",
        "subtitle":[
            "Values in RM '000",
            "• Click a state to explore its sector breakdown on the right •"
        ],
        "font":"Lora",
        "fontStyle":"normal",
        "fontSize":24,
        "anchor": "start",
        "subtitleFont": "Inter",
        "subtitleFontSize": 16
    },
    "data":{
        "url": "cleaned_floodloss_all.csv"
    },
    "params": [
        {
            "name": "year_select",
            "value":2024,
            "bind":{
                "input": "select",
                "options":[2024, 2025],
                "labels": ["2024", "2025"],
                "name": "Select Year: "
            }
        },
        {
            "name": "state_select",
            "value":"Kelantan"
        }
    ],
    "hconcat": [
        {
            "title":{
                "text":"Total Loss by State",
                "font":"Inter",
                "fontSize":13,
                "anchor": "start"
            },
            "width":350,
            "height":400,
            "transform": [
                {
                    "filter":"datum.State != 'Malaysia'"
                },
                {
                    "filter": "datum.Year == year_select"
                }
            ],
            "encoding": {
                "x":{
                            "field":"Total Loss",
                            "type": "quantitative",
                            "axis":{
                                "title":"Total Loss (RM '000)",
                                "titleFont":"Inter",
                                "titleFontSize":13,
                                "labelFont":"Inter",
                                "labelFontSize":12,
                                "grid": true,
                                "gridColor": "#e3e8ed",
                                "format":"~s"
                            }
                    },
                "y":{
                            "field":"State",
                            "type": "nominal",
                            "sort": {
                                "field":"Total Loss",
                                "op": "sum",
                                "order":"descending"
                            },
                            "axis":{
                                "title":null,
                                "labelFont":"Inter",
                                "labelFontSize":12
                            }
                        }
            },
            "layer": [
                {
                    "mark":{
                        "type": "bar",
                        "cornerRadiusTopRight": 3,
                        "cornerRadiusBottomRight": 3,
                        "opacity":1
                    },
                    "encoding": {
                        "color":{
                            "condition":{
                                "test":"datum.State == state_select",
                                "value": "#064869"
                            },
                            "value":"#8cc5e3"
                        },
                        "opacity":{
                            "condition":{
                                "test":"datum.State == state_select",
                                "value": 1
                            },
                            "value":0.5
                        },
                        "tooltip":[
                            {
                                "field":"State",
                                "type": "nominal",
                                "title":"State"
                            },
                            {
                                "field":"Year",
                                "type": "ordinal",
                                "title":"Year"
                            },
                            {
                                "field":"Total Loss",
                                "type": "quantitative",
                                "title":"Total Loss (RM '000)",
                                "format": ",.0f"
                            },
                            {
                                "field":"Living Quarters",
                                "type": "quantitative",
                                "title":"Living Quarters (RM '000)",
                                "format":",.0f"
                            },
                            {
                                "field":"Vehicles",
                                "type": "quantitative",
                                "title":"Vehicles (RM '000)",
                                "format":",.0f"
                            },
                            {
                                "field":"Business Premises",
                                "type": "quantitative",
                                "title":"Business Premises (RM '000)",
                                "format":",.0f"
                            },
                            {
                                "field":"Manufacturing",
                                "type": "quantitative",
                                "title":"Manufacturing (RM '000)",
                                "format":",.0f"
                            },
                            {
                                "field":"Agriculture",
                                "type": "quantitative",
                                "title":"Agriculture (RM '000)",
                                "format":",.0f"
                            },
                            {
                                "field":"Infrastructure",
                                "type": "quantitative",
                                "title":"Infrastructure (RM '000)",
                                "format":",.0f"
                            }
                        ]
                    }
                },
                {
                    "mark":{
                        "type": "point",
                        "filled": true,
                        "cursor":"pointer",
                        "opacity":1
                    },
                    "encoding": {
                        "color":{
                            "condition":{
                                "test":"datum.State == state_select",
                                "value": "#064869"
                            },
                            "value":"#8cc5e3"
                        },
                        "opacity":{
                            "condition":{
                                "test":"datum.State == state_select",
                                "value": 1
                            },
                            "value": 0.5
                        },
                        "size":{
                            "condition":{
                                "test":"datum.State == state_select",
                                "value": 350
                            },
                            "value":170
                        },
                        "tooltip":[
                            {
                                "field":"State",
                                "type": "nominal",
                                "title":"State"
                            },
                            {
                                "field":"Year",
                                "type": "ordinal",
                                "title":"Year"
                            },
                            {
                                "field":"Total Loss",
                                "type": "quantitative",
                                "title":"Total Loss (RM '000)",
                                "format":",.0f"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "title":{
                "text":{"expr": "state_select + ' Category Breakdown '"},
                "font":"Lora",
                "fontSize":18,
                "anchor": "start"
            },
            "width":350,
            "height": 350,
            "transform": [
                {
                    "filter":"datum.State == state_select"
                },
                {
                    "filter":"datum.Year == year_select"
                },
                {
                    "fold": [
                        "Living Quarters",
                        "Vehicles",
                        "Business Premises",
                        "Manufacturing",
                        "Agriculture",
                        "Infrastructure"
                    ],
                    "as": [
                        "Category", "Loss"
                    ]
                },
                {
                    "filter":"datum.Loss > 0"
                },
                {
                    "joinaggregate": [
                        {
                            "op": "sum",
                            "field": "Loss",
                            "as": "Total"
                        }
                    ]
                },
                {
                    "calculate": "datum.Loss / datum.Total * 100",
                    "as": "Percentage"
                }
            ],
            "mark":{
                "type": "arc",
                "innerRadius": 70,
                "stroke": "white",
                "strokeWidth": 0.5,
                "outerRadius": 130,
                "cursor": "pointer"
            },
            "encoding": {
                "theta":{
                    "field":"Percentage",
                    "type": "quantitative",
                    "stack":true
                },
                "color":{
                    "field":"Category",
                    "type": "nominal",
                    "scale":{
                        "domain":[
                            "Living Quarters",
                            "Vehicles",
                            "Business Premises",
                            "Manufacturing",
                            "Agriculture",
                            "Infrastructure"
                        ],
                        "range":[
                            "#f0a2ab",
                            "#bdba82",
                            "#f5b285",
                            "#93b7db",
                            "#a2d7bb",
                            "#bfa2db"
                        ]
                    },
                    "legend":{
                        "title":"Category",
                        "titleFont":"Inter",
                        "titleFontSize": 13,
                        "labelFont":"Inter",
                        "labelFontSize": 12
                    }
                },
                "tooltip":[
                    {
                        "field":"Category",
                        "type": "nominal",
                        "title":"Category"
                    },
                    {
                        "field":"Percentage",
                        "type": "quantitative",
                        "title":"Proportion (%)",
                        "format": ".1f"
                    },
                    {
                        "field":"Loss",
                        "type": "quantitative",
                        "title":"Loss (RM '000)",
                        "format": ",.0f"
                    }
                ]
            }
        }
    ],
    "config": {
        "font": "Inter",
        "view": {"stroke": null},
        "scale": {"bandPaddingInner": 0.8}
    }
}