{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title":{
        "text": "After the Water Recedes",
        "font": "Playfair Display",
        "fontStyle": "normal",
        "fontSize": 26,
        "fontWeight": "bold",
        "anchor": "start",
        "color":"#0a2343"
    },
    "data":{
        "url": "cleaned_floodloss_agricultural.csv"
    },
    "params": [
        {
            "name": "year_select",
            "value":2024,
            "bind":{
                "input": "select",
                "options":[2024, 2025],
                "labels": ["2024", "2025"],
                "name": "Select Year:"
            }
        },
        {
            "name": "state_select",
            "value":"Kelantan",
            "bind":{
                "input": "select",
                "options": [
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu",
                    "Kuala Lumpur",
                    "Putrajaya"
                ],
                "name": "Select State:"
            }
        }
    ],
    "resolve": {
        "scale": {"color": "independent"},
        "legend": {"color": "independent"}
    },
    "hconcat": [
        {
            "title":{
                "text": {"expr":"state_select+ ' Damage Profile'"},
                "font":"Playfair Display",
                "fontSize":18,
                "anchor": "start"
            },
            "width": 390,
            "height": 350,
        "transform": [
        {
            "filter": "datum.Year == year_select"
        },
        {
            "filter": "datum.State == state_select"
        },
        {
            "fold": [
                "Paddy",
                "Crops",
                "Fisheries",
                "Livestock",
                "Fisherman",
                "Agro-entrepreneur",
                "High Value Commodity"
            ],
            "as": [
                "Category",
                "Loss"
            ]
        },
        {
          "calculate": "toNumber(datum.Loss)",
          "as": "Loss_Num"
        },
        {
          "filter": "datum.Loss > 0"
        }
    ],
    "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 3,
        "cornerRadiusTopRight": 3
    },
    "encoding": {
        "x":{
            "field":"Category",
            "type": "nominal",
            "sort": {
                "op": "sum",
                "field": "Loss",
                "order":"descending"
            },
            "axis":{
                "labelAngle": -30,
                "labelFont":"DM Sans",
                "labelFontSize": 12,
                "labelColor":"#2c3e50",
                "title":null
            }
        },
        "y":{
            "field":"Loss_Num",
            "type": "quantitative",
            "scale":{
                "type": "linear",
                "domainMin": 0,
                "nice": true
            },
            "axis":{
                "title": "Loss (RM '000)",
                "titleFont": "DM Sans",
                "titleFontSize": 13,
                "labelFont": "DM Sans",
                "labelFontSize": 12,
                "grid": true,
                "gridColor":"#dce4ed",
                "tickCount": 5,
                "tickExtra": true
            }
        },
        "color":{
            "field": "Category",
            "type": "nominal",
            "scale":{
                "domain":[
                    "Paddy",
                    "Crops",
                    "Fisheries",
                    "Livestock",
                    "Fisherman",
                    "Agro-entrepreneur",
                    "High Value Commodity"
                ],
                "range":[
                    "#c99b38",
                    "#0d7d87",
                    "#8cc5e3",
                    "#4a2377",
                    "#f55f74",
                    "#003a7d",
                    "#ea801c"
                ]
            },
            "legend":null
        },
        "tooltip":[
            {
                "field": "Category",
                "type": "nominal",
                "title": "Category"
            },
            {
                "field": "Loss_Num",
                "type": "quantitative",
                "title": "Loss (RM '000)",
                "format": ",d"
            },
            {
                "field":"State",
                "type": "nominal",
                "title": "State"
            },
            {
                "field":"Year",
                "type": "ordinal",
                "title": "Year"
            }
        ]
    }
    },

    {
  "title": {
    "text": "How Loss Shifted · 2024 → 2025",
    "font": "Playfair Display",
    "fontSize": 18,
    "anchor": "start",
    "color": "#0a2343"
  },
  "width": 390,
  "height": 350,
  "resolve": {
    "scale": {"color": "independent"},
    "legend": {"color": "independent"}
  },
  "transform": [
    {
      "filter": "datum.State == state_select"
    },
    {
      "fold": [
        "Paddy",
        "Crops",
        "Fisheries",
        "Livestock",
        "Fisherman",
        "Agro-entrepreneur",
        "High Value Commodity"
      ],
      "as": ["Category", "Loss"]
    },
    {
      "calculate": "toNumber(datum.Loss)",
      "as": "Loss_Num"
    },
    {
        "filter": "datum.Loss_Num > 0"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Loss_Num",
          "as": "Total_Loss_Num"
        }
      ],
      "groupby": ["Category", "Year"]
    },
    {
      "pivot": "Year",
      "value": "Total_Loss_Num",
      "groupby": ["Category"]
    },
    {
      "calculate": "isValid(datum['2024']) ? datum['2024'] : 0",
      "as": "Loss_2024"
    },
    {
      "calculate": "isValid(datum['2025']) ? datum['2025'] : 0",
      "as": "Loss_2025"
    },
    {
      "calculate": "datum.Loss_2025 - datum.Loss_2024",
      "as": "Change"
    },
    {
      "filter": "datum.Change != 0"
    },
    {
          "calculate": "abs(datum.Change)",
          "as": "Abs_Change"
        },
    {
          "calculate": "datum.Change >= 0 ? 'Increase' : 'Decrease'",
          "as": "Direction"
        },
        {
          "calculate": "0",
          "as": "bar_start"
        },
        {
          "calculate": "datum.Change",
          "as": "bar_end"
        },
        {
            "calculate": "datum.Change >= 0 ? '↑ ' + format(datum.Change, '+,.0f') : '↓ ' + format(datum.Change, '+,.0f')",
            "as": "arrow_label"
        },
        {
          "calculate": "format(datum.Change, '+,.0f')",
          "as": "change_label"
        },
        {
          "window": [
            {
              "op": "rank",
              "as": "change_rank"
            }
          ],
          "sort": [
            {
              "field": "Abs_Change",
              "order": "descending"
            }
          ]
        }
  ],
  "layer": [
    {
        "mark":{
            "type": "rule",
            "color":"#0a2343",
            "strokeWidth":1.5,
            "strokeDash":[4,3]
        },
        "encoding": {
            "y": {
              "datum": 0,
              "type": "quantitative"
            }
          }
    },   
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 3,
        "cornerRadiusTopRight": 3,
        "cornerRadiusBottomLeft": 3,
        "cornerRadiusBottomRight": 3
      },
      "encoding": {
        "x": {
          "field": "Category",
          "type": "nominal",
          "sort": {
            "field": "Change",
            "order": "ascending"
          },
          "axis": {
            "labelFont": "DM Sans",
            "labelFontSize": 12,
            "labelAngle": -30,
            "title": null
          }
        },
        "y": {
          "field": "bar_start",
          "type": "quantitative",
          "scale":{
            "domainMid": 0},
          "axis": {
            "title": "Net Change (RM '000)",
            "titleFont": "DM Sans",
            "titleFontSize": 13,
            "labelFont": "DM Sans",
            "labelFontSize": 12,
            "grid": false
          }
        },
        "y2": {
          "field": "bar_end"
        },
        "color": {
          "field": "Direction",
              "type": "nominal",
              "scale": {
                "domain": [
                  "Increase",
                  "Decrease"
                ],
                "range": [
                  "#b03022",
                  "#6b7c93"
                ]
              },
              "legend": {
                "title": "Year-on-Year Change",
                "titleFont": "DM Sans",
                "titleFontSize": 13,
                "labelFont": "DM Sans",
                "labelFontSize": 12,
                "orient": "bottom"
              }
        },
        "tooltip": [
          {
            "field": "Category",
            "type": "nominal",
            "title": "Category"
          },
          {
            "field": "Loss_2024",
            "type": "quantitative",
            "title": "2024 Loss (RM '000)",
            "format": ",.0f"
          },
          {
            "field": "Loss_2025",
            "type": "quantitative",
            "title": "2025 Loss (RM '000)",
            "format": ",.0f"
          },
          {
            "field": "Change",
            "type": "quantitative",
            "title": "Change (RM '000)",
            "format": "+,.0f"
          }
        ]
      }
    },
    {
  "mark": {
    "type": "point",
    "shape":"square",
    "filled": true,
    "opacity": 0
  },
  "encoding": {
    "x": {
      "value": 0
    },
    "y": {
      "value": 0
    },
    "color": {
      "field": "Category",
      "type": "nominal",
      "scale": {
        "domain": [
          "Paddy",
          "Crops",
          "Fisheries",
          "Livestock",
          "Fisherman",
          "Agro-entrepreneur",
          "High Value Commodity"
        ],
        "range": [
          "#c99b38",
          "#0d7d87",
          "#8cc5e3",
          "#4a2377",
          "#f55f74",
          "#003a7d",
          "#ea801c"
        ]
      },
      "legend": {
        "title": "Category",
        "titleFont": "DM Sans",
        "titleFontSize": 13,
        "labelFont": "DM Sans",
        "labelFontSize": 12,
        "labelColor": "#2c3e50"
      }
    }
  }
},
    {
  "transform": [
    {
      "filter": "datum.Change >= 0"
    }
  ],
  "mark": {
    "type": "text",
    "font": "DM Sans",
    "fontSize": 12,
    "fontWeight": "bold",
    "baseline": "bottom",
    "dy": -4
  },
  "encoding": {
    "x": {
      "field": "Category",
      "type": "nominal",
      "sort": {
        "field": "Change",
        "order": "ascending"
      }
    },
    "y": {
      "field": "bar_end",
      "type": "quantitative"
    },
    "text": {
      "field": "arrow_label"
    },
    "color": {
      "field": "Direction",
      "type": "nominal",
      "scale": {
        "domain": ["Increase", "Decrease"],
        "range": ["#b03022", "#6b7c93"]
      },
      "legend": null
    }
  }
},
{
  "transform": [
    {
      "filter": "datum.Change < 0"
    }
  ],
  "mark": {
    "type": "text",
    "font": "DM Sans",
    "fontSize": 12,
    "fontWeight": "bold",
    "baseline": "top",
    "dy": 4
  },
  "encoding": {
    "x": {
      "field": "Category",
      "type": "nominal",
      "sort": {
        "field": "Change",
        "order": "ascending"
      }
    },
    "y": {
      "field": "bar_end",
      "type": "quantitative"
    },
    "text": {
      "field": "arrow_label"
    },
    "color": {
      "field": "Direction",
      "type": "nominal",
      "scale": {
        "domain": ["Increase", "Decrease"],
        "range": ["#b03022", "#6b7c93"]
      },
      "legend": null
    }
  }
}
  ]
}
],  
    "config": {
        "font": "DM Sans",
        "view": {"stroke":null}
    }
}