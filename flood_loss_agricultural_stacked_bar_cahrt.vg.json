{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Agricultural Flood Losses by State & Categories (2024)",
        "subtitle": "Total loss across all cateogories in RM'000\nClick a bar to filter the state",
        "font": "Lora",
        "fontStyle": "normal",
        "fontSize": 24,
        "anchor": "start",
        "subtitleFont": "Inter",
        "subtitleFontSize": 18
    },
    "width": 800,
    "height": 400,
    "data": { "url": "cleaned_floodloss_agricultural.csv" },
    "transform": [
        {
            "fold": [
                "Paddy",
                "Crops",
                "Fisheries",
                "Livestock",
                "Fisherman",
                "Agro-entrupreneur",
                "High_Value_Commodity"
            ],
            "as": [
                "Categories",
                "Loss"
            ]
        }
    ],
    "mark": { 
        "type": "bar",
        "cornerRadiusTopLeft": 3,
        "cornerRadiusTopRight": 3
    },
    "encoding": {
        "x": { "timeUnit": "yearmonth", "field": "date", "type": "ordinal", "title":null },
        "y": { "aggregate": "sum", "field": "new_cases", "title": "Sun of New Cases" },
        "color": { "field": "continent", "title": "Continent" }
    }
}